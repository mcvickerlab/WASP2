/*
========================================================================================
    ARM / Apple Silicon configuration for WASP2 RNA-seq ASE Pipeline
========================================================================================
    STAR and other bioinformatics tools do not publish native ARM (aarch64) container
    images. This config forces Docker to use linux/amd64 images via Rosetta 2
    emulation on Apple Silicon Macs.

    Usage:
        nextflow run main.nf -profile docker,arm [options]

    Prerequisites:
        - Docker Desktop 4.16+ with Rosetta 2 emulation enabled
        - macOS on Apple Silicon (M1/M2/M3/M4)

    Performance note:
        Expect ~2-3x slower execution compared to native x86_64 due to emulation.
----------------------------------------------------------------------------------------
*/

docker.runOptions = '-u $(id -u):$(id -g) --platform linux/amd64'
