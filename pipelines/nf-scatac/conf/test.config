/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-scatac Test Config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal test dataset for CI/CD
    Use as follows:
        nextflow run nf-scatac -profile test,<docker/singularity/conda>
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources for CI
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '1.h'

    // Test data (local paths using pre-generated test data)
    input = "${projectDir}/tests/data/samplesheet_test.csv"
    vcf   = "${projectDir}/tests/data/variants.vcf.gz"

    // Fast test parameters - relax thresholds for stub data
    min_fragments_per_cell = 1
    min_cells_per_snp      = 1
    min_count              = 1

    // Skip resource-intensive steps for faster CI
    skip_pseudobulk = true
}
