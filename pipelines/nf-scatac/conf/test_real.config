/*
 * nf-scatac test_real config - Integration test with GM12878 scATAC-seq data
 */

// Set WASP2_TEST_VCF to the local NA12878 (or matched) phased VCF before running.
params {
    config_profile_name    = 'Real data integration test'
    input                  = "${projectDir}/tests/real/samplesheet.csv"
    vcf                    = "${System.getenv('WASP2_TEST_VCF') ?: 'null'}"
    outdir                 = "${projectDir}/results_real"
    min_fragments_per_cell = 1000
    max_cpus               = 16
    max_memory             = '128.GB'
    max_time               = '48.h'
}
