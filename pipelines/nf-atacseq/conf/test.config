/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-atacseq test config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal test configuration for CI/CD and local testing
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '1.h'

    // Test data - uses pre-generated local synthetic test data
    input     = "${projectDir}/tests/data/samplesheet_test.csv"

    // References - local pre-built BWA index
    fasta     = "${projectDir}/tests/data/chr_test.fa"
    bwa_index = "${projectDir}/tests/data/bwa_index"

    // Variants
    vcf       = "${projectDir}/tests/data/variants.vcf.gz"

    // Skip certain steps for faster testing
    skip_dedup        = true
    skip_peak_calling = false
    macs_gsize        = '1.0e7'

    // WASP2 options
    wasp_min_count    = 1
    wasp_pseudocount  = 1
}
