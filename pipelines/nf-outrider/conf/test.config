/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-outrider Test Config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal test dataset for CI/CD
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources for CI
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '1.h'

    // Test data (local paths using pre-generated test data)
    input = "${projectDir}/tests/data/samplesheet_test.csv"
    vcf   = "${projectDir}/tests/data/variants.vcf.gz"
    gtf   = "${projectDir}/tests/data/annotation.gtf"

    // Fast test parameters
    outrider_iterations  = 2
    outrider_min_samples = 2
}
